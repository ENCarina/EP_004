import supertest from 'supertest';
import app from '../app/app.js';
import { expect } from 'chai';

describe('Auth Folyamat', () => {
    let token;

    it('Sikeres Regisztráció és Login', async () => {
        // 1. Regisztráció
        const reg = await supertest(app)
            .post('/api/register')
            .send({
                name: 'Mary Test',
                email: 'mary@zold.lan',
                password: 'secret',
                password_confirmation: 'secret'
            });
        expect(reg.status).to.equal(201);

        // 2. Login
        const login = await supertest(app)
            .post('/api/login')
            .send({
                email: 'mary@zold.lan',
                password: 'secret'
            });
        
        expect(login.status).to.equal(200);
        token = login.body.token || login.body.accessToken || login.body.data?.token;
        expect(token).to.not.be.undefined;
    });

    it('Védett útvonal elérése', async () => {
        const res = await supertest(app)
            .get('/api/users')
            .set('Authorization', `Bearer ${token}`);
        expect(res.status).to.equal(200);
    });
});